{
  "name": "dialsort",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "test": "vitest run",
    "check": "tsc --noEmit && eslint . && prettier --check . && vitest run",
    "lint": "eslint",
    "worker": "ts-node --project tsconfig.json -e \"require('./src/lib/queue/call-worker').startCallWorker()\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --project tsconfig.json prisma/seed.ts"
  },
  "prisma": {
    "seed": "npm run db:seed"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@twilio/voice-sdk": "^2.18.3",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "papaparse": "^5.5.3",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "recharts": "^3.8.1",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^3.15.9",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
